---
interface Props {
  title: string;
  description: string;
  slug: string;
  image: string;
  category: string;
  readTime: string;
  datePublished: string;
  index?: number;
}

const { title, description, slug, image, category, readTime, datePublished, index = 0 } = Astro.props;

const num = String(index + 1).padStart(3, '0');
const pageUrl = `https://coastalhomeau.com.au/blog/${slug}`;
const pinUrl  = `https://pinterest.com/pin/create/button/?url=${encodeURIComponent(pageUrl)}&media=${encodeURIComponent(image)}&description=${encodeURIComponent(title)}`;

const date = new Date(datePublished).toLocaleDateString('en-AU', {
  day: 'numeric', month: 'short', year: 'numeric',
});
---

<article class="post-card">
  <a href={`/blog/${slug}`} class="card-img-link" tabindex="-1" aria-hidden="true">
    <div class="img-wrap card-img">
      <img
        src={image}
        alt={title}
        width="800"
        height="450"
        loading="lazy"
        decoding="async"
      />
      <a
        href={pinUrl}
        class="pin-btn"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Save "${title}" to Pinterest`}
        onclick="event.stopPropagation()"
      >
        <svg viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
        Save
      </a>
    </div>
  </a>

  <div class="card-meta-row">
    <span class="card-category">{category}</span>
  </div>

  <div class="card-body">
    <h3 class="card-title">
      <a href={`/blog/${slug}`}>{title}</a>
    </h3>
    <p class="card-excerpt">{description}</p>
    <div class="card-footer">
      <time class="card-date" datetime={datePublished}>{date}</time>
      <span class="card-read">{readTime}</span>
    </div>
  </div>
</article>

<style>
.post-card {
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
  transition: box-shadow var(--transition);
}
.post-card:hover { box-shadow: var(--shadow-hover); }

.card-img-link { display: block; }
.card-img {
  border-radius: 0;
  aspect-ratio: 16 / 9;
}

.card-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 0 0;
  border-top: 1px solid var(--color-border);
  margin-top: 0;
}
.card-num {
  font-family: var(--font-heading);
  font-size: 0.68rem;
  font-weight: 500;
  color: var(--color-text-muted);
  letter-spacing: 0.04em;
}
.card-category {
  font-family: var(--font-heading);
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-primary);
}

.card-body {
  padding: 12px 0 28px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex: 1;
}

.card-title {
  font-family: var(--font-display);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(1.1rem, 2vw, 1.35rem);
  line-height: 1.3;
  margin: 0;
  color: var(--color-heading);
}
.card-title a { color: inherit; text-decoration: none; }
.card-title a:hover { color: var(--color-primary); text-decoration: none; }

.card-excerpt {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  line-height: 1.65;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-footer {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: auto;
}
.card-date,
.card-read {
  font-family: var(--font-heading);
  font-size: 0.72rem;
  color: var(--color-text-muted);
  letter-spacing: 0.02em;
}
.card-date::after { content: '·'; margin-left: 12px; }
</style>
