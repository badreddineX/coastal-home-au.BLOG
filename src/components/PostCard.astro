---
interface Props {
  title: string;
  description: string;
  slug: string;
  image: string;
  category: string;
  readTime: string;
  datePublished: string;
}

const { title, description, slug, image, category, readTime, datePublished } = Astro.props;

const date = new Date(datePublished).toLocaleDateString('en-AU', {
  day: 'numeric', month: 'short', year: 'numeric',
});
---

<article class="post-card">
  <a href={`/blog/${slug}`} class="card-img-link" tabindex="-1" aria-hidden="true">
    <div class="img-wrap card-img">
      <img
        src={image}
        alt={title}
        width="800"
        height="450"
        loading="lazy"
        decoding="async"
      />
    </div>
  </a>

  <div class="card-meta-row">
    <span class="card-category">{category}</span>
  </div>

  <div class="card-body">
    <h3 class="card-title">
      <a href={`/blog/${slug}`}>{title}</a>
    </h3>
    <p class="card-excerpt">{description}</p>
    <div class="card-footer">
      <time class="card-date" datetime={datePublished}>{date}</time>
      <span class="card-read">{readTime}</span>
    </div>
  </div>
</article>

<style>
.post-card {
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
  transition: box-shadow var(--transition);
}
.post-card:hover { box-shadow: var(--shadow-hover); }

.card-img-link { display: block; }
.card-img {
  border-radius: 0;
  aspect-ratio: 16 / 9;
}

.card-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 0 0;
  border-top: 1px solid var(--color-border);
  margin-top: 0;
}
.card-category {
  font-family: var(--font-heading);
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-primary);
}

.card-body {
  padding: 12px 0 28px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex: 1;
}

.card-title {
  font-family: var(--font-display);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(1.1rem, 2vw, 1.35rem);
  line-height: 1.3;
  margin: 0;
  color: var(--color-heading);
}
.card-title a { color: inherit; text-decoration: none; }
.card-title a:hover { color: var(--color-primary); text-decoration: none; }

.card-excerpt {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  line-height: 1.65;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-footer {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: auto;
}
.card-date,
.card-read {
  font-family: var(--font-heading);
  font-size: 0.72rem;
  color: var(--color-text-muted);
  letter-spacing: 0.02em;
}
.card-date::after { content: '·'; margin-left: 12px; }
</style>
