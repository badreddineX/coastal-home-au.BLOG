---
const year = new Date().getFullYear();
const categories = [
  { label: 'Outdoor Entertaining', href: '/blog?cat=outdoor-entertaining' },
  { label: 'Coastal Decor',        href: '/blog?cat=coastal-decor'        },
  { label: 'Hamptons Style',       href: '/blog?cat=hamptons-style'       },
  { label: 'Backyard Ideas',       href: '/blog?cat=backyard-ideas'       },
];
---

<footer class="site-footer">
  <div class="footer-main">
    <div class="container footer-inner">

      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="footer-logo-monogram">O&amp;H</span>
          <span class="footer-logo-wordmark">Outdoor &amp; Coastal-Home</span>
        </a>
        <p>Outdoor living and coastal decor ideas for Australian homes. Written from the Southern Hemisphere, for the Australian lifestyle.</p>

        <div class="social-icons">
          <a href="#" aria-label="Pinterest (coming soon)" class="social-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
          </a>
          <a href="#" aria-label="Instagram (coming soon)" class="social-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </a>
          <a href="#" aria-label="Facebook (coming soon)" class="social-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073c0 6.027 4.388 11.024 10.125 11.927v-8.437H7.078v-3.49h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.49h-2.796v8.437C19.612 23.097 24 18.1 24 12.073z"/></svg>
          </a>
        </div>
      </div>

      <div class="footer-col">
        <h3>Topics</h3>
        <ul>
          {categories.map(c => <li><a href={c.href}>{c.label}</a></li>)}
        </ul>
      </div>

      <div class="footer-col">
        <h3>Pages</h3>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/privacy-policy">Privacy Policy</a></li>
        </ul>
      </div>

    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-disclosure">Affiliate links present — commission earned at no extra cost to you.</p>
      <p class="footer-copy">&copy; {year} Outdoor &amp; Coastal Home Decor</p>
    </div>
  </div>
</footer>

<style>
.site-footer { border-top: 1px solid var(--color-border); }

.footer-main { background: var(--color-dark); }

.footer-inner {
  display: grid;
  grid-template-columns: 1fr;
  gap: 48px;
  padding-top: 64px;
  padding-bottom: 48px;
}

/* Logotype in footer */
.footer-logo {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  text-decoration: none;
  margin-bottom: 16px;
  line-height: 1;
}
.footer-logo:hover { text-decoration: none; }
.footer-logo-monogram {
  font-family: 'Pinyon Script', cursive;
  font-weight: 400;
  font-size: 2.8rem;
  color: var(--color-white);
  line-height: 1;
  letter-spacing: 0.02em;
}
.footer-logo-wordmark {
  font-family: var(--font-heading);
  font-size: 0.5rem;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  white-space: nowrap;
}

.social-icons {
  display: flex;
  gap: 12px;
  margin-top: 20px;
}
.social-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border: 1px solid rgba(255,255,255,0.15);
  color: rgba(255,255,255,0.5);
  transition: all var(--transition);
  text-decoration: none;
}
.social-icon:hover {
  border-color: var(--color-primary);
  color: var(--color-white);
  background: rgba(74,144,184,0.15);
  text-decoration: none;
}

.footer-brand p {
  font-size: 0.875rem;
  line-height: 1.65;
  color: rgba(255,255,255,0.45);
  max-width: 280px;
  margin: 0;
}

.footer-col h3 {
  font-family: var(--font-heading);
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--color-accent);
  margin-bottom: 20px;
}
.footer-col ul { list-style: none; padding: 0; margin: 0; }
.footer-col li { margin-bottom: 12px; }
.footer-col a {
  font-size: 0.875rem;
  color: rgba(255,255,255,0.55);
  transition: color var(--transition);
}
.footer-col a:hover { color: var(--color-white); text-decoration: none; }

.footer-bottom {
  background: var(--color-dark);
  border-top: 1px solid rgba(255,255,255,0.08);
  padding: 20px 0;
}
.footer-bottom-inner {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.footer-disclosure,
.footer-copy {
  font-size: 0.75rem;
  color: rgba(255,255,255,0.3);
  font-family: var(--font-heading);
  letter-spacing: 0.02em;
  margin: 0;
}

@media (min-width: 640px) {
  .footer-inner { grid-template-columns: 2fr 1fr 1fr; }
  .footer-bottom-inner { flex-direction: row; justify-content: space-between; align-items: center; }
}
</style>
