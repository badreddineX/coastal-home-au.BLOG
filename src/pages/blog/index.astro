---
import { getCollection } from 'astro:content';
import SEO      from '../../components/SEO.astro';
import Header   from '../../components/Header.astro';
import Footer   from '../../components/Footer.astro';
import PostCard  from '../../components/PostCard.astro';
import '../../styles/global.css';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime()
);

const categories = ['Outdoor Entertaining', 'Coastal Decor', 'Hamptons Style', 'Backyard Ideas'];
---

<!doctype html>
<html lang="en-AU">
  <head>
    <SEO
      title="Blog — Outdoor & Coastal Home Decor"
      description="Browse all outdoor entertaining, coastal decor, and Hamptons style ideas for Australian homes."
      path="/blog"
      type="website"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <Header />
    <main id="main-content">

      <!-- Hero -->
      <section class="blog-hero">
        <img
          class="blog-hero-bg"
          src="https://images.unsplash.com/photo-1600566753086-00f18fb6b3ea?auto=format&fit=crop&w=1600&q=80"
          alt="Australian coastal outdoor living area"
          width="1600" height="700"
          loading="eager" fetchpriority="high"
        />
        <div class="blog-hero-overlay" aria-hidden="true"></div>
        <div class="container blog-hero-content">
          <h1 class="display blog-title">All Ideas</h1>
          <p class="blog-sub">Outdoor living, coastal decor, and Hamptons style ideas — written for Australian homes.</p>
        </div>
      </section>

      <!-- Search + Filter bar -->
      <div class="filter-bar">
        <div class="container filter-inner">

          <!-- Search -->
          <div class="search-wrap">
            <svg class="search-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.5"/>
              <path d="M13.5 13.5l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <input
              id="search-input"
              type="search"
              placeholder="Search ideas..."
              aria-label="Search blog posts"
              autocomplete="off"
              role="combobox"
              aria-expanded="false"
              aria-controls="search-suggestions"
              aria-autocomplete="list"
              data-posts={JSON.stringify(allPosts.map(p => ({
                t: p.data.title,
                c: p.data.category,
                s: `/blog/${p.slug}`,
              })))}
            />
            <button id="search-clear" class="search-clear" aria-label="Clear search" hidden>
              <svg viewBox="0 0 16 16" fill="none" width="14" height="14">
                <path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </button>
            <ul id="search-suggestions" class="suggestions-list" role="listbox" hidden></ul>
          </div>

          <!-- Category filters -->
          <div class="cat-filters" role="group" aria-label="Filter by category">
            <button class="cat-filter active" data-cat="all">All</button>
            {categories.map(cat => (
              <button class="cat-filter" data-cat={cat}>{cat}</button>
            ))}
          </div>

        </div>
      </div>

      <!-- Posts grid -->
      <section class="section posts-section" aria-label="Blog posts" aria-live="polite">
        <div class="container">
          <div class="grid-2" id="posts-grid">
            {allPosts.map((post, i) => (
              <div
                class="post-item"
                data-title={post.data.title.toLowerCase()}
                data-desc={post.data.description.toLowerCase()}
                data-cat={post.data.category}
                data-index={i}
              >
                <PostCard
                  title={post.data.title}
                  description={post.data.description}
                  slug={post.slug}
                  image={post.data.image}
                  category={post.data.category}
                  readTime={post.data.readTime}
                  datePublished={post.data.datePublished}
                  index={i}
                />
              </div>
            ))}
          </div>

          <!-- Empty state: search no results -->
          <div id="empty-state" class="empty-state" hidden>
            <p class="display empty-title">No Results Found</p>
            <p class="empty-sub">Try a different search term or browse another category.</p>
            <button class="btn btn-outline" id="reset-btn">Clear filters</button>
          </div>

          <!-- Empty state: category has no posts yet -->
          <div id="coming-soon" class="empty-state" hidden>
            <p class="display empty-title">Coming Soon</p>
            <p class="empty-sub">We're working on articles for this category. Check back soon.</p>
            <a href="/blog" class="btn btn-outline">Browse All Ideas</a>
          </div>

          <!-- Pagination -->
          <nav id="pagination" class="pagination" aria-label="Page navigation" hidden>
            <button class="page-btn page-prev" id="page-prev" aria-label="Previous page">&#8249;</button>
            <div class="page-numbers" id="page-numbers"></div>
            <button class="page-btn page-next" id="page-next" aria-label="Next page">&#8250;</button>
          </nav>
        </div>
      </section>

    </main>
    <Footer />
  </body>
</html>

<style>
/* Hero */
.blog-hero {
  position: relative;
  width: 100%;
  height: 52vh;
  min-height: 340px;
  max-height: 520px;
  display: flex;
  align-items: center;
  overflow: hidden;
}
.blog-hero-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 60%;
}
.blog-hero-overlay {
  position: absolute;
  inset: 0;
  background: rgba(15, 25, 35, 0.52);
}
.blog-hero-content {
  position: relative;
  z-index: 2;
  padding-top: 0;
  padding-bottom: 0;
}
.blog-title {
  font-size: clamp(3rem, 8vw, 5.5rem);
  line-height: 1;
  margin: 0 0 16px 0;
  color: #ffffff;
  text-shadow: 0 2px 20px rgba(0,0,0,0.3);
}
.blog-sub {
  font-size: 1rem;
  color: rgba(255,255,255,0.85);
  max-width: 480px;
  margin: 0;
  text-shadow: 0 1px 8px rgba(0,0,0,0.3);
}

/* Filter bar */
.filter-bar {
  position: sticky;
  top: 72px;
  z-index: 100;
  background: rgba(253, 252, 251, 0.97);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--color-border);
  overflow: visible;
}

.filter-inner {
  display: flex;
  flex-direction: column;
  gap: 16px;
  padding-top: 20px;
  padding-bottom: 20px;
}

/* Search */
.search-wrap {
  position: relative;
  display: flex;
  align-items: center;
  max-width: 420px;
  width: 100%;
}
.search-icon {
  position: absolute;
  left: 14px;
  width: 16px;
  height: 16px;
  color: var(--color-text-muted);
  pointer-events: none;
  flex-shrink: 0;
}
#search-input {
  width: 100%;
  padding: 11px 40px 11px 42px;
  border: 1px solid #ddd8d2;
  background: #ffffff;
  font-family: var(--font-body);
  font-size: 0.92rem;
  color: #1a1a1a;
  outline: none;
  transition: border-color 0.15s ease;
  border-radius: 4px;
}
#search-input::placeholder { color: #a09890; }
#search-input:focus { border-color: #b0a89e; }
#search-input::-webkit-search-cancel-button { display: none; }

.search-clear {
  position: absolute;
  right: 4px;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--color-text-muted);
  padding: 12px;
  min-width: 44px;
  min-height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: color var(--transition);
}
.search-clear:hover { color: var(--color-heading); }

/* Suggestions dropdown */
.suggestions-list {
  position: absolute;
  top: calc(100% + 4px);
  left: 0;
  right: 0;
  background: #ffffff;
  border: 1px solid #e8e2db;
  box-shadow: 0 6px 20px rgba(0,0,0,0.08);
  list-style: none;
  padding: 0;
  margin: 0;
  z-index: 300;
  max-height: 400px;
  overflow-y: auto;
  border-radius: 4px;
}
:global(.suggestion-item) {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 16px 20px;
  cursor: pointer;
  border-bottom: 1px solid #f0ece8;
  transition: background 0.15s ease;
}
:global(.suggestion-item:last-child) { border-bottom: none; }
:global(.suggestion-item:hover),
:global(.suggestion-item[aria-selected="true"]) { background: #faf8f5; }
:global(.suggestion-cat-pill) {
  flex-shrink: 0;
  font-family: 'Inter', sans-serif;
  font-size: 0.6rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.09em;
  color: #8a8078;
  border: 1px solid #c5bdb5;
  border-radius: 4px;
  padding: 4px 10px;
  white-space: nowrap;
  background: transparent;
  min-width: 56px;
  text-align: center;
}
:global(.suggestion-title) {
  font-family: 'Inter', sans-serif;
  font-size: 0.92rem;
  font-weight: 400;
  color: #1a1a1a;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
  min-width: 0;
}
:global(.suggestion-title mark) {
  background: rgba(196, 170, 130, 0.22);
  color: inherit;
  font-weight: 500;
  border-radius: 2px;
  padding: 1px 2px;
}

/* Category filter pills */

.cat-filters {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding-bottom: 2px;
}
.cat-filters::-webkit-scrollbar { display: none; }
.cat-filter {
  padding: 10px 16px;
  background: transparent;
  border: 1px solid var(--color-border);
  font-family: var(--font-heading);
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--color-text-muted);
  cursor: pointer;
  transition: all var(--transition);
  border-radius: 2px;
  white-space: nowrap;
  min-height: 44px;
  flex-shrink: 0;
}
.cat-filter:hover {
  border-color: var(--color-primary);
  color: var(--color-primary);
}
.cat-filter.active {
  background: var(--color-heading);
  border-color: var(--color-heading);
  color: var(--color-white);
}

/* Posts */
.posts-section { padding-top: 48px; }
.post-item { transition: opacity 0.2s ease; }
.post-item[hidden] { display: none; }

/* Pagination */
.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  padding: 56px 0 16px;
  border-top: 1px solid var(--color-border);
  margin-top: 48px;
}
.page-numbers {
  display: flex;
  align-items: center;
  gap: 4px;
  margin: 0 8px;
}
.page-btn {
  appearance: none;
  -webkit-appearance: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  background: none;
  border: none;
  outline: none;
  box-shadow: none;
  color: var(--color-text-muted);
  cursor: pointer;
  transition: color var(--transition);
  font-size: 1rem;
}
.page-btn:hover:not(:disabled) { color: var(--color-heading); }
.page-btn:disabled { opacity: 0.25; cursor: not-allowed; }
:global(.page-num) {
  appearance: none;
  -webkit-appearance: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: transparent;
  border: none;
  outline: none;
  box-shadow: none;
  font-family: 'Inter', sans-serif;
  font-style: normal;
  font-size: 1rem;
  font-weight: 400;
  color: var(--color-heading);
  cursor: pointer;
  transition: background 0.2s ease, color 0.2s ease;
}
:global(.page-num:hover:not(.active)) { background: var(--color-surface-warm); }
:global(.page-num.active) {
  background: var(--color-heading);
  color: #ffffff;
  font-weight: 600;
}

/* Empty state */
.empty-state {
  text-align: center;
  padding: 80px 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}
.empty-title {
  font-size: clamp(1.8rem, 4vw, 2.5rem);
  color: var(--color-heading);
  line-height: 1.1;
}
.empty-sub {
  color: var(--color-text-muted);
  font-size: 0.95rem;
  margin: 0;
}
.empty-reset { margin-top: 8px; }

@media (min-width: 640px) {
  .filter-inner {
    flex-direction: row;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .search-wrap { flex-shrink: 0; }
}

@media (max-width: 480px) {
  .pagination { gap: 2px; padding: 40px 0 12px; }
  .page-btn { width: 32px; height: 32px; font-size: 1.1rem; }
}
:global(.page-ellipsis) {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 40px;
  color: var(--color-text-muted);
  font-size: 0.9rem;
  pointer-events: none;
  user-select: none;
}
@media (max-width: 480px) {
  :global(.page-num) { width: 32px; height: 32px; font-size: 0.875rem; }
  :global(.page-ellipsis) { width: 20px; height: 32px; font-size: 0.875rem; }
}
</style>

<script>
const searchInput    = document.getElementById('search-input') as HTMLInputElement | null;
const suggestionsList = document.getElementById('search-suggestions') as HTMLUListElement | null;
const searchClear  = document.getElementById('search-clear') as HTMLButtonElement | null;
const catFilters   = document.querySelectorAll<HTMLButtonElement>('.cat-filter');
const postItems    = document.querySelectorAll<HTMLElement>('.post-item');
const emptyState   = document.getElementById('empty-state') as HTMLElement | null;
const comingSoon   = document.getElementById('coming-soon') as HTMLElement | null;
const resetBtn     = document.getElementById('reset-btn') as HTMLButtonElement | null;
const pagination   = document.getElementById('pagination') as HTMLElement | null;
const pageNumbers  = document.getElementById('page-numbers') as HTMLElement | null;
const pagePrev     = document.getElementById('page-prev') as HTMLButtonElement | null;
const pageNext     = document.getElementById('page-next') as HTMLButtonElement | null;

if (!searchInput || !pagination || !pageNumbers || !pagePrev || !pageNext || !emptyState || !comingSoon || !resetBtn) {
  console.warn('Blog filter: required elements missing');
}

// Read post data directly from the input's data attribute (injected at build time)
const postIndex: { t: string; c: string; s: string }[] = JSON.parse(
  searchInput?.dataset.posts ?? '[]'
);

let activeSuggestionIdx = -1;

function showSuggestions(query: string) {
  if (!suggestionsList || !searchInput) return;
  if (query.length < 1) { hideSuggestions(); return; }

  const matches = postIndex.filter(p =>
    p.t.toLowerCase().includes(query) || p.c.toLowerCase().includes(query)
  ).slice(0, 6);

  if (matches.length === 0) { hideSuggestions(); return; }

  const esc = (s: string) => s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  const highlight = (text: string) =>
    text.replace(new RegExp(`(${esc(query)})`, 'gi'), '<mark>$1</mark>');

  const catLabel: Record<string, string> = {
    'Outdoor Entertaining': 'Outdoor',
    'Coastal Decor': 'Coastal',
    'Hamptons Style': 'Hamptons',
    'Backyard Ideas': 'Backyard',
  };

  suggestionsList.innerHTML = matches.map((p, i) => `
    <li role="option" aria-selected="false" class="suggestion-item" data-href="${p.s}" data-idx="${i}">
      <span class="suggestion-cat-pill">${catLabel[p.c] ?? p.c}</span>
      <span class="suggestion-title">${highlight(p.t)}</span>
    </li>
  `).join('');

  suggestionsList.hidden = false;
  searchInput.setAttribute('aria-expanded', 'true');
  activeSuggestionIdx = -1;

  suggestionsList.querySelectorAll<HTMLElement>('.suggestion-item').forEach(item => {
    item.addEventListener('mousedown', (e) => {
      e.preventDefault();
      const href = item.dataset.href;
      if (href) window.location.href = href;
    });
  });
}

function hideSuggestions() {
  if (!suggestionsList || !searchInput) return;
  suggestionsList.hidden = true;
  suggestionsList.innerHTML = '';
  searchInput.setAttribute('aria-expanded', 'false');
  activeSuggestionIdx = -1;
}

function navigateSuggestions(dir: 1 | -1) {
  if (!suggestionsList || suggestionsList.hidden) return;
  const items = suggestionsList.querySelectorAll<HTMLElement>('.suggestion-item');
  if (!items.length) return;
  items[activeSuggestionIdx]?.setAttribute('aria-selected', 'false');
  activeSuggestionIdx = Math.max(-1, Math.min(items.length - 1, activeSuggestionIdx + dir));
  if (activeSuggestionIdx >= 0) {
    items[activeSuggestionIdx].setAttribute('aria-selected', 'true');
    if (searchInput) searchInput.value = items[activeSuggestionIdx].querySelector('.suggestion-title')?.textContent ?? '';
  }
}

const PER_PAGE = 6;
let activeCategory = 'all';
let searchQuery    = '';
let currentPage    = 1;
let isFiltering    = false;
let matched: HTMLElement[] = [];

const urlParams = new URLSearchParams(window.location.search);
const urlCat    = urlParams.get('cat');
const slugToLabel: Record<string, string> = {
  'outdoor-entertaining': 'Outdoor Entertaining',
  'coastal-decor':        'Coastal Decor',
  'hamptons-style':       'Hamptons Style',
  'backyard-ideas':       'Backyard Ideas',
};
if (urlCat && slugToLabel[urlCat]) {
  activeCategory = slugToLabel[urlCat];
  isFiltering = true;
  catFilters.forEach(btn => {
    btn.classList.remove('active');
    if (btn.dataset.cat === activeCategory) btn.classList.add('active');
  });
}

function buildPagination(total: number) {
  if (!pagination || !pageNumbers || !pagePrev || !pageNext) return;
  const totalPages = Math.ceil(total / PER_PAGE);
  pagination.hidden = totalPages <= 1 || isFiltering;
  if (pagination.hidden) return;
  pageNumbers.innerHTML = '';

  const isMobile = window.innerWidth <= 480;

  if (isMobile && totalPages > 3) {
    const slots: (number | 'ellipsis')[] = [];
    if (currentPage <= 2) {
      slots.push(1, 2, 'ellipsis', totalPages);
    } else if (currentPage >= totalPages - 1) {
      slots.push(1, 'ellipsis', totalPages - 1, totalPages);
    } else {
      slots.push(1, 'ellipsis', currentPage, 'ellipsis', totalPages);
    }
    slots.forEach(p => {
      if (p === 'ellipsis') {
        const el = document.createElement('span');
        el.className = 'page-ellipsis';
        el.textContent = '…';
        pageNumbers.appendChild(el);
      } else {
        const btn = document.createElement('button');
        btn.className = 'page-num' + (p === currentPage ? ' active' : '');
        btn.textContent = String(p);
        btn.setAttribute('aria-label', `Page ${p}`);
        btn.addEventListener('click', () => goToPage(p as number));
        pageNumbers.appendChild(btn);
      }
    });
  } else {
    for (let i = 1; i <= totalPages; i++) {
      const btn = document.createElement('button');
      btn.className = 'page-num' + (i === currentPage ? ' active' : '');
      btn.textContent = String(i);
      btn.setAttribute('aria-label', `Page ${i}`);
      btn.addEventListener('click', () => goToPage(i));
      pageNumbers.appendChild(btn);
    }
  }

  pagePrev.disabled = currentPage === 1;
  pageNext.disabled = currentPage === totalPages;
}

function goToPage(page: number) {
  currentPage = page;
  applyFilters();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function applyFilters() {
  matched = [];
  postItems.forEach(item => {
    const title = item.dataset.title ?? '';
    const desc  = item.dataset.desc  ?? '';
    const cat   = item.dataset.cat   ?? '';
    const matchesCat    = activeCategory === 'all' || cat === activeCategory;
    const matchesSearch = searchQuery === '' || title.includes(searchQuery) || desc.includes(searchQuery);
    if (matchesCat && matchesSearch) matched.push(item);
  });

  const total = matched.length;

  if (isFiltering) {
    postItems.forEach(item => { item.hidden = true; });
    matched.forEach(item => { item.hidden = false; });
  } else {
    const start = (currentPage - 1) * PER_PAGE;
    const end   = start + PER_PAGE;
    postItems.forEach(item => { item.hidden = true; });
    matched.forEach((item, i) => { item.hidden = i < start || i >= end; });
  }

  if (emptyState) emptyState.hidden = !(searchQuery !== '' && total === 0);
  if (comingSoon) comingSoon.hidden = !(activeCategory !== 'all' && searchQuery === '' && total === 0);
  buildPagination(total);
}

pagePrev?.addEventListener('click', () => { if (currentPage > 1) goToPage(currentPage - 1); });
pageNext?.addEventListener('click', () => {
  const totalPages = Math.ceil(matched.length / PER_PAGE);
  if (currentPage < totalPages) goToPage(currentPage + 1);
});

catFilters.forEach(btn => {
  btn.addEventListener('click', () => {
    catFilters.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeCategory = btn.dataset.cat ?? 'all';
    isFiltering    = activeCategory !== 'all';
    currentPage    = 1;
    applyFilters();
  });
});

searchInput?.addEventListener('input', () => {
  searchQuery  = searchInput!.value.toLowerCase().trim();
  isFiltering  = searchQuery !== '' || activeCategory !== 'all';
  currentPage  = 1;
  if (searchClear) searchClear.hidden = searchQuery === '';
  showSuggestions(searchQuery);
  applyFilters();
});

searchInput?.addEventListener('keydown', (e) => {
  if (e.key === 'ArrowDown') { e.preventDefault(); navigateSuggestions(1); }
  else if (e.key === 'ArrowUp') { e.preventDefault(); navigateSuggestions(-1); }
  else if (e.key === 'Enter' && activeSuggestionIdx >= 0) {
    const item = suggestionsList?.querySelectorAll<HTMLElement>('.suggestion-item')[activeSuggestionIdx];
    if (item?.dataset.href) { e.preventDefault(); window.location.href = item.dataset.href; }
  }
  else if (e.key === 'Escape') hideSuggestions();
});

searchInput?.addEventListener('blur', () => setTimeout(hideSuggestions, 150));

searchClear?.addEventListener('click', () => {
  if (searchInput) searchInput.value = '';
  searchQuery        = '';
  isFiltering        = activeCategory !== 'all';
  currentPage        = 1;
  if (searchClear) searchClear.hidden = true;
  hideSuggestions();
  searchInput?.focus();
  applyFilters();
});

resetBtn?.addEventListener('click', () => {
  if (searchInput) searchInput.value = '';
  searchQuery        = '';
  isFiltering        = false;
  currentPage        = 1;
  if (searchClear) searchClear.hidden = true;
  activeCategory     = 'all';
  catFilters.forEach(b => b.classList.remove('active'));
  catFilters[0]?.classList.add('active');
  applyFilters();
});

// Run on load
applyFilters();
</script>
