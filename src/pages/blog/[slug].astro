---
import { getCollection }  from 'astro:content';
import BlogPost            from '../../layouts/BlogPost.astro';
import TLDRBox             from '../../components/TLDRBox.astro';
import FAQ                 from '../../components/FAQ.astro';
import PostCard            from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

const {
  title,
  description,
  image,
  datePublished,
  dateModified,
  author = 'Badreddine Br',
  category,
  readTime,
  tldr = [],
  faqs = [],
} = post.data;

const allPosts = await getCollection('blog');
const related = allPosts
  .filter(p => p.slug !== post.slug)
  .sort((a, b) => {
    const aMatch = a.data.category === category ? 1 : 0;
    const bMatch = b.data.category === category ? 1 : 0;
    if (bMatch !== aMatch) return bMatch - aMatch;
    return new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime();
  })
  .slice(0, 3);

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
function stripTipPrefix(text: string) {
  return text.replace(/^tip\s*\d+\s*[:–-]\s*/i, '');
}

const formattedDate = new Date(datePublished).toLocaleDateString('en-AU', {
  day: 'numeric', month: 'long', year: 'numeric',
});

const siteUrl = 'https://coastalhomeau.com.au';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',  item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Blog',  item: `${siteUrl}/blog` },
    { '@type': 'ListItem', position: 3, name: title,   item: `${siteUrl}/blog/${post.slug}` },
  ],
};

---

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

{faqs.length > 0 && (
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map(f => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  })} />
)}

<div class="reading-progress" id="reading-progress" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" aria-label="Reading progress"></div>

<button id="back-to-top" class="back-to-top" aria-label="Back to top">
  <svg viewBox="0 0 16 16" fill="none" width="18" height="18" aria-hidden="true">
    <path d="M8 12V4M4 8l4-4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</button>

<BlogPost
  title={title}
  description={description}
  slug={post.slug}
  image={image}
  datePublished={datePublished}
  dateModified={dateModified}
  author={author}
>
  <div class="post-wrap">

    <!-- ── Post header (full width) ── -->
    <div class="post-header-wrap">
      <div class="post-header container">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span class="breadcrumb-sep" aria-hidden="true">›</span>
          <a href="/blog">Blog</a>
          <span class="breadcrumb-sep" aria-hidden="true">›</span>
          <span aria-current="page">{category}</span>
        </nav>

        <span class="pill post-cat">{category}</span>
        <h1 class="display post-title">{title}</h1>

        <div class="post-meta">
          <span class="post-meta-author">{author}</span>
          <span aria-hidden="true" class="post-meta-sep">·</span>
          <time datetime={datePublished}>{formattedDate}</time>
          <span aria-hidden="true" class="post-meta-sep">·</span>
          <span>{readTime}</span>
        </div>
      </div>
    </div>

    <!-- ── Two-column layout ── -->
    <div class="container post-layout">

      <!-- Main content -->
      <article class="post-main">

        <!-- Featured image -->
        <div class="img-wrap post-hero-img">
          <img
            src={image}
            alt={title}
            width="1200"
            height="675"
            loading="eager"
            fetchpriority="high"
          />
        </div>

        <!-- TL;DR -->
        {tldr.length > 0 && <TLDRBox points={tldr} />}

        <!-- Mobile-only TOC -->
        {tocHeadings.length > 0 && (
          <nav class="toc-mobile" aria-label="Table of contents">
            <details>
              <summary class="toc-mobile-summary">
                <span>Table of Contents</span>
                <svg viewBox="0 0 20 20" fill="none" aria-hidden="true" width="14" height="14">
                  <path d="M5 7l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </summary>
              <ol class="toc-mobile-list">
                {tocHeadings.map(h => (
                  <li class={h.depth === 3 ? 'toc-sub' : ''}>
                    <a href={`#${h.slug}`}>{stripTipPrefix(h.text)}</a>
                  </li>
                ))}
              </ol>
            </details>
          </nav>
        )}

        <!-- Content -->
        <div class="post-content post-body">
          <Content />
        </div>

        <!-- FAQ -->
        {faqs.length > 0 && <FAQ questions={faqs} />}

        <!-- Author bio -->
        <div class="author-bio">
          <div class="author-bio-logo" aria-hidden="true">
            <span class="bio-logo-initial">B</span>
          </div>
          <div>
            <span class="author-bio-name">{author}</span>
            <p>
              Badreddine is a home decor enthusiast sharing coastal living and outdoor entertaining ideas for Australian homes — with the right seasons, the right retailers, and the right climate in mind.
            </p>
          </div>
        </div>

      </article>

      <!-- Sticky sidebar -->
      <aside class="post-sidebar">

        <!-- TOC Widget -->
        <div class="toc-widget" id="sidebar-toc">
          <div class="toc-widget__header" id="toc-header">
            <h2 class="toc-widget__header-title">Table of Contents</h2>
            <button type="button" class="toc-widget__toggle-button toc-widget__toggle-button--collapse" aria-label="Close table of contents">
              <svg viewBox="0 0 448 512"><path d="M240.971 130.524l194.343 194.343c9.373 9.373 9.373 24.569 0 33.941l-22.667 22.667c-9.357 9.357-24.522 9.375-33.901.04L224 227.495 69.255 381.516c-9.379 9.335-24.544 9.317-33.901-.04l-22.667-22.667c-9.373-9.373-9.373-24.569 0-33.941L207.03 130.525c9.372-9.373 24.568-9.373 33.941-.001z"/></svg>
            </button>
            <button type="button" class="toc-widget__toggle-button toc-widget__toggle-button--expand" aria-label="Open table of contents">
              <svg viewBox="0 0 448 512"><path d="M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z"/></svg>
            </button>
          </div>
          <div class="toc-widget__body" id="toc-body">
            <ol class="toc-widget__list" id="sidebar-toc-list"></ol>
          </div>
        </div>

        <!-- Share widget -->
        <div class="share-widget">
          <p class="share-label">Share This Article</p>
          <div class="share-btns">
            <a
              href={`https://pinterest.com/pin/create/button/?url=https://coastalhomeau.com.au/blog/${post.slug}&media=${encodeURIComponent(image)}&description=${encodeURIComponent(title)}`}
              target="_blank" rel="noopener noreferrer"
              class="share-btn share-btn--pinterest"
              aria-label="Save to Pinterest"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
              <span>Pinterest</span>
            </a>
            <a
              href={`https://www.facebook.com/sharer/sharer.php?u=https://coastalhomeau.com.au/blog/${post.slug}`}
              target="_blank" rel="noopener noreferrer"
              class="share-btn share-btn--facebook"
              aria-label="Share on Facebook"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073c0 6.027 4.388 11.024 10.125 11.927v-8.437H7.078v-3.49h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.49h-2.796v8.437C19.612 23.097 24 18.1 24 12.073z"/></svg>
              <span>Facebook</span>
            </a>
            <button class="share-btn share-btn--copy" id="copy-link-btn" aria-label="Copy link">
              <svg viewBox="0 0 24 24" fill="none" width="18" height="18"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span id="copy-btn-text">Copy Link</span>
            </button>
          </div>
        </div>

        <!-- Category card -->
        <div class="sidebar-card">
          <p class="sidebar-card-label">Browse More</p>
          <p class="sidebar-card-title">Explore all coastal &amp; outdoor ideas</p>
          <a href="/blog" class="btn btn-primary sidebar-card-btn">
            View all ideas
            <svg viewBox="0 0 16 16" fill="none" width="12" height="12" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </a>
        </div>

      </aside>

    </div>

    <!-- ── Related posts (full width) ── -->
    {related.length > 0 && (
      <section class="related-section" aria-labelledby="related-heading">
        <div class="container">
          <h2 class="display related-title" id="related-heading">Read Next</h2>
          <div class="grid-3 related-grid">
            {related.map((p, i) => (
              <PostCard
                title={p.data.title}
                description={p.data.description}
                slug={p.slug}
                image={p.data.image}
                category={p.data.category}
                readTime={p.data.readTime}
                datePublished={p.data.datePublished}
                index={i}
              />
            ))}
          </div>
        </div>
      </section>
    )}

  </div>
</BlogPost>

<style>
/* ── Wrapper ── */
.post-wrap { padding-bottom: 80px; }

/* ── Post header ── */
.post-header-wrap {
  border-bottom: 1px solid var(--color-border);
  padding: 32px 0 28px;
}
@media (min-width: 768px) {
  .post-header-wrap { padding: 48px 0 40px; }
}
.post-cat { margin-bottom: 16px; display: inline-block; }

.post-title {
  font-size: clamp(1.6rem, 4.5vw, 3rem);
  margin: 0 0 1.25rem 0;
  line-height: 1.15;
  max-width: 780px;
  overflow-wrap: break-word;
  word-break: break-word;
}

.post-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-heading);
  font-size: 0.82rem;
  color: var(--color-text-muted);
  flex-wrap: wrap;
}
.post-meta-author { font-weight: 600; color: var(--color-heading); }
.post-meta-sep { color: var(--color-border); }

.post-header {
  overflow-x: hidden;
}

/* ── Two-column layout ── */
.post-layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: 48px;
  padding-top: 40px;
  align-items: start;
}

@media (min-width: 1024px) {
  .post-layout {
    grid-template-columns: 1fr 300px;
    gap: 64px;
  }
}

/* ── Main content ── */
.post-main {
  overflow-x: hidden;
  overflow-wrap: break-word;
  word-break: break-word;
  min-width: 0;
}

.post-hero-img {
  margin: 0 0 2rem;
  aspect-ratio: 16 / 9;
  border-radius: 2px;
  overflow: hidden;
}


/* Mobile TOC */
.toc-mobile {
  border-radius: 8px;
  margin: 0 0 2rem;
  display: block;
  overflow: hidden;
  background: #EDE5D8;
}
.toc-mobile-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 20px;
  cursor: pointer;
  list-style: none;
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-heading);
  background: #DDD0BC;
}
.toc-mobile-summary::-webkit-details-marker { display: none; }
.toc-mobile-summary svg { color: var(--color-heading); transition: transform 0.2s; }
details[open] .toc-mobile-summary svg { transform: rotate(180deg); }
.toc-mobile-list {
  padding: 12px 20px 18px 20px;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
  counter-reset: toc-counter;
}
.toc-mobile-list li {
  counter-increment: toc-counter;
  display: flex;
  gap: 10px;
  align-items: flex-start;
}
.toc-mobile-list li::before {
  content: counter(toc-counter) ".";
  font-family: var(--font-heading);
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--color-heading);
  min-width: 18px;
  padding-top: 6px;
  flex-shrink: 0;
}
.toc-mobile-list a {
  font-size: 0.875rem;
  color: var(--color-heading);
  text-decoration: none;
  padding: 5px 0;
  line-height: 1.4;
  transition: color var(--transition);
}
.toc-mobile-list a:hover { color: #8B6914; text-decoration: none; }

@media (min-width: 1024px) {
  .toc-mobile { display: none; }
}

/* Post content */
.post-content { margin: 0 0 2rem; }
.post-content :global(h2) {
  font-family: var(--font-display);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(1.4rem, 3vw, 1.9rem);
  color: #111111;
  margin-top: 2.5rem;
  line-height: 1.3;
  border-bottom: 2px solid var(--color-border);
  padding-bottom: 6px;
  overflow-wrap: break-word;
  word-break: break-word;
  min-width: 0;
}
.post-content :global(h3) {
  font-family: var(--font-heading);
  font-style: normal;
  font-weight: 600;
  font-size: clamp(1rem, 2vw, 1.15rem);
  color: var(--color-primary);
  text-decoration: underline;
  text-underline-offset: 3px;
  margin-top: 1.8rem;
  overflow-wrap: break-word;
  word-break: break-word;
  min-width: 0;
}
.post-content :global(.img-wrap) {
  margin: 2rem 0;
  aspect-ratio: 16 / 9;
}
.post-content :global(img) {
  max-width: 100%;
  height: auto;
}

/* Author bio */
.author-bio {
  display: flex;
  align-items: flex-start;
  gap: 20px;
  margin-top: 3rem;
  padding: 28px;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
}
.author-bio-logo {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: var(--color-heading);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.bio-logo-initial {
  font-family: var(--font-heading);
  font-size: 1.7rem;
  font-weight: 700;
  color: var(--color-white);
  line-height: 1;
  letter-spacing: -0.02em;
}
.author-bio-name {
  display: block;
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 0.85rem;
  letter-spacing: 0.04em;
  color: var(--color-heading);
  margin-bottom: 6px;
}
.author-bio p {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  line-height: 1.65;
  margin: 0;
}

/* ── Sidebar ── */
.post-sidebar {
  display: flex;
  flex-direction: column;
  gap: 32px;
}

@media (min-width: 1024px) {
  .post-sidebar {
    position: sticky;
    top: 88px; /* header height + gap */
  }
}

/* TOC Widget */
.toc-widget {
  background: var(--color-surface-warm);
  border: 1px solid var(--color-border);
  border-radius: 6px;
  font-family: var(--font-heading);
}
.toc-widget__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 20px;
  cursor: pointer;
  background: var(--color-heading);
  border-radius: 6px 6px 0 0;
  user-select: none;
}
.toc-widget__header-title {
  margin: 0;
  flex: 1;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #ffffff;
}
.toc-widget__toggle-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  background: none;
  border: none;
  padding: 0;
  cursor: pointer;
  color: rgba(255,255,255,0.7);
}
.toc-widget__toggle-button svg { width: 12px; height: 12px; fill: currentColor; }
.toc-widget__toggle-button--collapse { display: flex; }
.toc-widget__toggle-button--expand   { display: none; }
.toc-widget.is-collapsed .toc-widget__toggle-button--collapse { display: none; }
.toc-widget.is-collapsed .toc-widget__toggle-button--expand   { display: flex; }
.toc-widget.is-collapsed .toc-widget__header { border-radius: 6px; }
.toc-widget__body {
  overflow-y: auto;
  max-height: min(2000px, calc(100vh - 180px));
  transition: max-height 0.3s ease;
  border-top: 1px solid var(--color-border);
  scrollbar-width: thin;
}
.toc-widget.is-collapsed .toc-widget__body {
  max-height: 0;
  overflow: hidden;
  border-top-color: transparent;
}
:global(.toc-widget__list) {
  list-style: none;
  counter-reset: toc-counter;
  margin: 0;
  padding: 18px 20px;
  display: flex;
  flex-direction: column;
  gap: 0;
}
:global(.toc-widget__list-item) {
  counter-increment: toc-counter;
  margin-bottom: 12px;
}
:global(.toc-widget__list-item:last-child) { margin-bottom: 0; }
:global(.toc-widget__list-item-text-wrapper) {
  display: flex;
  align-items: baseline;
  gap: 10px;
}
:global(.toc-widget__list-item-text-wrapper::before) {
  content: counter(toc-counter) ".";
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--color-text-muted);
  min-width: 20px;
  flex-shrink: 0;
}
:global(.toc-widget__list-item-text) {
  font-size: 0.875rem;
  line-height: 1.5;
  color: var(--color-heading) !important;
  text-decoration: none !important;
  transition: color 0.2s;
}
:global(.toc-widget__list-item-text:hover) { color: var(--color-primary) !important; text-decoration: none !important; }
:global(.toc-widget__list-item-text.is-active) { color: var(--color-primary) !important; font-weight: 600; }

/* Sidebar card */
.sidebar-card {
  background: var(--color-dark);
  padding: 28px 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.sidebar-card-label {
  font-family: var(--font-heading);
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--color-accent);
  margin: 0;
}
.sidebar-card-title {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1.2rem;
  color: var(--color-white);
  line-height: 1.3;
  margin: 0;
}
.sidebar-card-btn {
  align-self: flex-start;
  margin-top: 4px;
  font-size: 0.75rem;
}

/* ── Reading progress bar ── */
.reading-progress {
  position: fixed;
  top: 0;
  left: 0;
  width: 0%;
  height: 3px;
  background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
  z-index: 9999;
  transition: width 0.1s linear;
  pointer-events: none;
}

/* ── Back to top ── */
.back-to-top {
  position: fixed;
  bottom: 28px;
  right: 28px;
  width: 44px;
  height: 44px;
  background: var(--color-heading);
  color: #ffffff;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 500;
  opacity: 0;
  transform: translateY(12px);
  transition: opacity 0.3s ease, transform 0.3s ease, background 0.2s ease;
  pointer-events: none;
  border-radius: 2px;
  box-shadow: 0 4px 16px rgba(0,0,0,0.18);
}
.back-to-top.is-visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: all;
}
.back-to-top:hover { background: var(--color-primary); }

/* ── Share widget ── */
.share-widget {
  border: 1px solid var(--color-border);
  padding: 20px;
  border-radius: 6px;
  background: var(--color-bg);
}
.share-label {
  font-family: var(--font-heading);
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--color-text-muted);
  margin: 0 0 14px 0;
}
.share-btns {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.share-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  border-radius: 4px;
  font-family: var(--font-heading);
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-decoration: none;
  transition: all 0.2s ease;
  cursor: pointer;
  border: 1px solid transparent;
}
.share-btn:hover { text-decoration: none; }
.share-btn--pinterest {
  background: #E60023;
  color: #ffffff;
}
.share-btn--pinterest:hover { background: #c0001d; color: #ffffff; }
.share-btn--facebook {
  background: #1877F2;
  color: #ffffff;
}
.share-btn--facebook:hover { background: #0f5ec0; color: #ffffff; }
.share-btn--copy {
  background: transparent;
  color: var(--color-heading);
  border-color: var(--color-border);
}
.share-btn--copy:hover { background: var(--color-surface-warm); border-color: var(--color-heading); }
.share-btn--copy.copied { background: var(--color-accent-green); color: #ffffff; border-color: transparent; }

/* ── Related posts ── */
.related-section {
  padding: 72px 0;
  background: var(--color-surface-warm);
  margin-top: 3rem;
}
.related-title {
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  margin: 0 0 40px 0;
  line-height: 1.1;
}
.related-grid { gap: 32px; }
.related-grid :global(.post-card) { background: var(--color-bg); }
</style>

<script>
// ── Reading progress bar ──
(function () {
  const bar = document.getElementById('reading-progress');
  if (!bar) return;
  function updateProgress() {
    const scrollTop  = window.scrollY;
    const docHeight  = document.documentElement.scrollHeight - window.innerHeight;
    const pct        = docHeight > 0 ? Math.min(100, (scrollTop / docHeight) * 100) : 0;
    bar.style.width  = pct + '%';
    bar.setAttribute('aria-valuenow', String(Math.round(pct)));
  }
  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();
})();

// ── Back to top ──
(function () {
  const btn = document.getElementById('back-to-top');
  if (!btn) return;
  window.addEventListener('scroll', () => {
    btn.classList.toggle('is-visible', window.scrollY > 400);
  }, { passive: true });
  btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
})();

// ── Copy link ──
(function () {
  const copyBtn  = document.getElementById('copy-link-btn');
  const copyText = document.getElementById('copy-btn-text');
  if (!copyBtn || !copyText) return;
  copyBtn.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(window.location.href);
      copyBtn.classList.add('copied');
      copyText.textContent = 'Copied!';
      setTimeout(() => {
        copyBtn.classList.remove('copied');
        copyText.textContent = 'Copy Link';
      }, 2200);
    } catch {
      copyText.textContent = 'Copy failed';
      setTimeout(() => { copyText.textContent = 'Copy Link'; }, 2000);
    }
  });
})();

// ── TOC + scroll spy ──
(function () {
  const headings   = document.querySelectorAll('.post-body h2');
  const tocList    = document.getElementById('sidebar-toc-list');
  const sidebarToc = document.getElementById('sidebar-toc');
  const tocBody    = document.getElementById('toc-body');

  if ([...headings].length < 2) {
    sidebarToc?.remove();
    return;
  }

  headings.forEach((h, i) => {
    if (!h.id) h.id = `section-${i}`;
    const li      = document.createElement('li');
    li.className  = 'toc-widget__list-item';
    const wrapper = document.createElement('div');
    wrapper.className = 'toc-widget__list-item-text-wrapper';
    const a       = document.createElement('a');
    a.className   = 'toc-widget__list-item-text';
    a.href        = `#${h.id}`;
    a.textContent = (h.textContent?.trim() ?? '').replace(/^tip\s*\d+\s*[:–-]\s*/i, '');
    wrapper.appendChild(a);
    li.appendChild(wrapper);
    tocList?.appendChild(li);
  });

  const links = [...(tocList?.querySelectorAll('.toc-widget__list-item-text') ?? [])];
  let prevActive = -1;

  function scrollTocToActive(index) {
    if (!tocBody || index < 0) return;
    const item = links[index]?.closest('li');
    if (!item) return;
    const itemTop    = (item as HTMLElement).offsetTop;
    const itemBottom = itemTop + (item as HTMLElement).offsetHeight;
    const scrollTop  = tocBody.scrollTop;
    const height     = tocBody.clientHeight;
    if (itemTop < scrollTop + 16)               tocBody.scrollTop = itemTop - 16;
    else if (itemBottom > scrollTop + height - 16) tocBody.scrollTop = itemBottom - height + 16;
  }

  function setActive() {
    let active = -1;
    headings.forEach((h, i) => {
      if (h.getBoundingClientRect().top <= window.innerHeight * 0.35) active = i;
    });
    links.forEach((l, i) => l.classList.toggle('is-active', i === active));
    if (active !== prevActive) { prevActive = active; scrollTocToActive(active); }
  }

  setActive();
  window.addEventListener('scroll', () => requestAnimationFrame(setActive), { passive: true });

  document.getElementById('toc-header')?.addEventListener('click', () => {
    sidebarToc?.classList.toggle('is-collapsed');
  });

  if (window.innerWidth <= 640) sidebarToc?.classList.add('is-collapsed');
})();
</script>
