---
import { getCollection }  from 'astro:content';
import BlogPost            from '../../layouts/BlogPost.astro';
import TLDRBox             from '../../components/TLDRBox.astro';
import FAQ                 from '../../components/FAQ.astro';
import PostCard            from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

const {
  title,
  description,
  image,
  datePublished,
  dateModified,
  author = 'Sarah Mitchell',
  category,
  readTime,
  tldr = [],
  faqs = [],
} = post.data;

const allPosts = await getCollection('blog');
const related = allPosts
  .filter(p => p.slug !== post.slug)
  .sort((a, b) => {
    const aMatch = a.data.category === category ? 1 : 0;
    const bMatch = b.data.category === category ? 1 : 0;
    if (bMatch !== aMatch) return bMatch - aMatch;
    return new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime();
  })
  .slice(0, 3);

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);

const formattedDate = new Date(datePublished).toLocaleDateString('en-AU', {
  day: 'numeric', month: 'long', year: 'numeric',
});

---

{faqs.length > 0 && (
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map(f => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  })} />
)}

<BlogPost
  title={title}
  description={description}
  slug={post.slug}
  image={image}
  datePublished={datePublished}
  dateModified={dateModified}
  author={author}
>
  <div class="post-wrap">

    <!-- ── Post header (full width) ── -->
    <div class="post-header-wrap">
      <div class="post-header container">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span class="breadcrumb-sep" aria-hidden="true">›</span>
          <a href="/blog">Blog</a>
          <span class="breadcrumb-sep" aria-hidden="true">›</span>
          <span aria-current="page">{category}</span>
        </nav>

        <span class="pill post-cat">{category}</span>
        <h1 class="display post-title">{title}</h1>

        <div class="post-meta">
          <span class="post-meta-author">{author}</span>
          <span aria-hidden="true" class="post-meta-sep">·</span>
          <time datetime={datePublished}>{formattedDate}</time>
          <span aria-hidden="true" class="post-meta-sep">·</span>
          <span>{readTime}</span>
        </div>
      </div>
    </div>

    <!-- ── Two-column layout ── -->
    <div class="container post-layout">

      <!-- Main content -->
      <article class="post-main">

        <!-- Affiliate disclosure -->
        <p class="disclosure">
          <strong>Disclosure:</strong> This post contains affiliate links. If you purchase through my links I may earn a small commission at no extra cost to you.
        </p>

        <!-- Featured image -->
        <div class="img-wrap post-hero-img">
          <img
            src={image}
            alt={title}
            width="1200"
            height="675"
            loading="eager"
            fetchpriority="high"
          />
        </div>

        <!-- TL;DR -->
        {tldr.length > 0 && <TLDRBox points={tldr} />}

        <!-- Mobile-only TOC -->
        {tocHeadings.length > 0 && (
          <nav class="toc-mobile" aria-label="Table of contents">
            <details>
              <summary class="toc-mobile-summary">
                <span>Table of Contents</span>
                <svg viewBox="0 0 20 20" fill="none" aria-hidden="true" width="14" height="14">
                  <path d="M5 7l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </summary>
              <ol class="toc-mobile-list">
                {tocHeadings.map(h => (
                  <li class={h.depth === 3 ? 'toc-sub' : ''}>
                    <a href={`#${h.slug}`}>{h.text}</a>
                  </li>
                ))}
              </ol>
            </details>
          </nav>
        )}

        <!-- Content -->
        <div class="post-content post-body">
          <Content />
        </div>

        <!-- FAQ -->
        {faqs.length > 0 && <FAQ questions={faqs} />}

        <!-- Affiliate disclosure full -->
        <div class="disclosure disclosure--full">
          <strong>Affiliate Disclosure:</strong> This post contains affiliate links to products I genuinely recommend. If you purchase through my links I may earn a small commission at no extra cost to you. Thank you for supporting Outdoor & Coastal Home Decor.
        </div>

        <!-- Author bio -->
        <div class="author-bio">
          <div class="author-bio-logo" aria-hidden="true">
            <span class="bio-logo-monogram">O &amp; H</span>
          </div>
          <div>
            <span class="author-bio-name">{author}</span>
            <p>
              Sarah is a home decor enthusiast based on the Gold Coast, sharing coastal living and outdoor entertaining ideas for Australian homes — with the right seasons, the right retailers, and the right climate in mind.
            </p>
          </div>
        </div>

      </article>

      <!-- Sticky sidebar -->
      <aside class="post-sidebar">

        <!-- TOC Widget -->
        <div class="toc-widget" id="sidebar-toc">
          <div class="toc-widget__header" id="toc-header">
            <h2 class="toc-widget__header-title">Table of Contents</h2>
            <button type="button" class="toc-widget__toggle-button toc-widget__toggle-button--collapse" aria-label="Close table of contents">
              <svg viewBox="0 0 448 512"><path d="M240.971 130.524l194.343 194.343c9.373 9.373 9.373 24.569 0 33.941l-22.667 22.667c-9.357 9.357-24.522 9.375-33.901.04L224 227.495 69.255 381.516c-9.379 9.335-24.544 9.317-33.901-.04l-22.667-22.667c-9.373-9.373-9.373-24.569 0-33.941L207.03 130.525c9.372-9.373 24.568-9.373 33.941-.001z"/></svg>
            </button>
            <button type="button" class="toc-widget__toggle-button toc-widget__toggle-button--expand" aria-label="Open table of contents">
              <svg viewBox="0 0 448 512"><path d="M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z"/></svg>
            </button>
          </div>
          <div class="toc-widget__body" id="toc-body">
            <ol class="toc-widget__list" id="sidebar-toc-list"></ol>
          </div>
        </div>

        <!-- Category card -->
        <div class="sidebar-card">
          <p class="sidebar-card-label">Browse More</p>
          <p class="sidebar-card-title">Explore all coastal &amp; outdoor ideas</p>
          <a href="/blog" class="btn btn-primary sidebar-card-btn">
            View all ideas
            <svg viewBox="0 0 16 16" fill="none" width="12" height="12" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </a>
        </div>

      </aside>

    </div>

    <!-- ── Related posts (full width) ── -->
    {related.length > 0 && (
      <section class="related-section" aria-labelledby="related-heading">
        <div class="container">
          <h2 class="display related-title" id="related-heading">Read Next</h2>
          <div class="grid-3 related-grid">
            {related.map((p, i) => (
              <PostCard
                title={p.data.title}
                description={p.data.description}
                slug={p.slug}
                image={p.data.image}
                category={p.data.category}
                readTime={p.data.readTime}
                datePublished={p.data.datePublished}
                index={i}
              />
            ))}
          </div>
        </div>
      </section>
    )}

  </div>
</BlogPost>

<style>
/* ── Wrapper ── */
.post-wrap { padding-bottom: 80px; }

/* ── Post header ── */
.post-header-wrap {
  border-bottom: 1px solid var(--color-border);
  padding: 32px 0 28px;
}
@media (min-width: 768px) {
  .post-header-wrap { padding: 48px 0 40px; }
}
.post-cat { margin-bottom: 16px; display: inline-block; }

.post-title {
  font-size: clamp(1.9rem, 4.5vw, 3rem);
  margin: 0 0 1.25rem 0;
  line-height: 1.1;
  max-width: 780px;
}

.post-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-heading);
  font-size: 0.82rem;
  color: var(--color-text-muted);
  flex-wrap: wrap;
}
.post-meta-author { font-weight: 600; color: var(--color-heading); }
.post-meta-sep { color: var(--color-border); }

/* ── Two-column layout ── */
.post-layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: 48px;
  padding-top: 40px;
  align-items: start;
}

@media (min-width: 1024px) {
  .post-layout {
    grid-template-columns: 1fr 300px;
    gap: 64px;
  }
}

/* ── Main content ── */
.post-hero-img {
  margin: 0 0 2rem;
  aspect-ratio: 16 / 9;
  border-radius: 2px;
  overflow: hidden;
}

.disclosure {
  font-size: 0.78rem;
  color: var(--color-text-muted);
  border-left: 3px solid var(--color-border);
  padding: 8px 12px;
  margin: 0 0 1.5rem;
  line-height: 1.6;
}
.disclosure--full {
  margin: 2.5rem 0 0;
  font-size: 0.8rem;
}

/* Mobile TOC */
.toc-mobile {
  border-radius: 8px;
  margin: 0 0 2rem;
  display: block;
  overflow: hidden;
  background: #EDE5D8;
}
.toc-mobile-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 20px;
  cursor: pointer;
  list-style: none;
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-heading);
  background: #DDD0BC;
}
.toc-mobile-summary::-webkit-details-marker { display: none; }
.toc-mobile-summary svg { color: var(--color-heading); transition: transform 0.2s; }
details[open] .toc-mobile-summary svg { transform: rotate(180deg); }
.toc-mobile-list {
  padding: 12px 20px 18px 20px;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
  counter-reset: toc-counter;
}
.toc-mobile-list li {
  counter-increment: toc-counter;
  display: flex;
  gap: 10px;
  align-items: flex-start;
}
.toc-mobile-list li::before {
  content: counter(toc-counter) ".";
  font-family: var(--font-heading);
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--color-heading);
  min-width: 18px;
  padding-top: 6px;
  flex-shrink: 0;
}
.toc-mobile-list a {
  font-size: 0.875rem;
  color: var(--color-heading);
  text-decoration: none;
  padding: 5px 0;
  line-height: 1.4;
  transition: color var(--transition);
}
.toc-mobile-list a:hover { color: #8B6914; text-decoration: none; }

@media (min-width: 1024px) {
  .toc-mobile { display: none; }
}

/* Post content */
.post-content { margin: 0 0 2rem; }
.post-content :global(h2) {
  font-family: var(--font-display);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(1.5rem, 3vw, 2rem);
  color: var(--color-heading);
  border-bottom: 1px solid var(--color-border);
  padding-bottom: 8px;
  margin-top: 2.5rem;
}
.post-content :global(h3) {
  font-family: var(--font-display);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(1.2rem, 2.5vw, 1.5rem);
  color: var(--color-heading);
  margin-top: 2rem;
}
.post-content :global(.img-wrap) {
  margin: 2rem 0;
  aspect-ratio: 16 / 9;
}

/* Author bio */
.author-bio {
  display: flex;
  align-items: flex-start;
  gap: 20px;
  margin-top: 3rem;
  padding: 28px;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
}
.author-bio-logo {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: var(--color-heading);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.bio-logo-monogram {
  font-family: 'Pinyon Script', cursive;
  font-size: 1.6rem;
  color: var(--color-white);
  line-height: 1;
  letter-spacing: 0.02em;
}
.author-bio-name {
  display: block;
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 0.85rem;
  letter-spacing: 0.04em;
  color: var(--color-heading);
  margin-bottom: 6px;
}
.author-bio p {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  line-height: 1.65;
  margin: 0;
}

/* ── Sidebar ── */
.post-sidebar {
  display: flex;
  flex-direction: column;
  gap: 32px;
}

@media (min-width: 1024px) {
  .post-sidebar {
    position: sticky;
    top: 88px; /* header height + gap */
  }
}

/* TOC Widget */
.toc-widget {
  background: var(--color-surface-warm);
  border: 1px solid var(--color-border);
  border-radius: 6px;
  font-family: var(--font-heading);
}
.toc-widget__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 20px;
  cursor: pointer;
  background: var(--color-heading);
  border-radius: 6px 6px 0 0;
  user-select: none;
}
.toc-widget__header-title {
  margin: 0;
  flex: 1;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #ffffff;
}
.toc-widget__toggle-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 18px;
  height: 18px;
  background: none;
  border: none;
  padding: 0;
  cursor: pointer;
  color: rgba(255,255,255,0.7);
}
.toc-widget__toggle-button svg { width: 12px; height: 12px; fill: currentColor; }
.toc-widget__toggle-button--collapse { display: flex; }
.toc-widget__toggle-button--expand   { display: none; }
.toc-widget.is-collapsed .toc-widget__toggle-button--collapse { display: none; }
.toc-widget.is-collapsed .toc-widget__toggle-button--expand   { display: flex; }
.toc-widget.is-collapsed .toc-widget__header { border-radius: 6px; }
.toc-widget__body {
  overflow-y: auto;
  max-height: min(2000px, calc(100vh - 180px));
  transition: max-height 0.3s ease;
  border-top: 1px solid var(--color-border);
  scrollbar-width: thin;
}
.toc-widget.is-collapsed .toc-widget__body {
  max-height: 0;
  overflow: hidden;
  border-top-color: transparent;
}
.toc-widget__list {
  list-style: none;
  counter-reset: toc-counter;
  margin: 0;
  padding: 18px 20px;
  display: flex;
  flex-direction: column;
  gap: 0;
}
.toc-widget__list-item {
  counter-increment: toc-counter;
  margin-bottom: 12px;
}
.toc-widget__list-item:last-child { margin-bottom: 0; }
.toc-widget__list-item-text-wrapper {
  display: flex;
  align-items: baseline;
  gap: 10px;
}
.toc-widget__list-item-text-wrapper::before {
  content: counter(toc-counter) ".";
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--color-text-muted);
  min-width: 20px;
  flex-shrink: 0;
}
.toc-widget__list-item-text {
  font-size: 0.875rem;
  line-height: 1.5;
  color: var(--color-heading);
  text-decoration: none;
  transition: color 0.2s;
}
.toc-widget__list-item-text:hover { color: var(--color-primary); text-decoration: none; }
.toc-widget__list-item-text.is-active { color: var(--color-primary); font-weight: 600; }

/* Sidebar card */
.sidebar-card {
  background: var(--color-dark);
  padding: 28px 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.sidebar-card-label {
  font-family: var(--font-heading);
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--color-accent);
  margin: 0;
}
.sidebar-card-title {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1.2rem;
  color: var(--color-white);
  line-height: 1.3;
  margin: 0;
}
.sidebar-card-btn {
  align-self: flex-start;
  margin-top: 4px;
  font-size: 0.75rem;
}

/* ── Related posts ── */
.related-section {
  padding: 72px 0;
  background: var(--color-surface-warm);
  margin-top: 3rem;
}
.related-title {
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  margin: 0 0 40px 0;
  line-height: 1.1;
}
.related-grid { gap: 32px; }
.related-grid :global(.post-card) { background: var(--color-bg); }
</style>

<script>
(function () {
  const headings   = document.querySelectorAll('.post-body h2');
  const tocList    = document.getElementById('sidebar-toc-list');
  const sidebarToc = document.getElementById('sidebar-toc');
  const tocBody    = document.getElementById('toc-body');

  if ([...headings].length < 2) {
    sidebarToc?.remove();
    return;
  }

  headings.forEach((h, i) => {
    if (!h.id) h.id = `section-${i}`;
    const li      = document.createElement('li');
    li.className  = 'toc-widget__list-item';
    const wrapper = document.createElement('div');
    wrapper.className = 'toc-widget__list-item-text-wrapper';
    const a       = document.createElement('a');
    a.className   = 'toc-widget__list-item-text';
    a.href        = `#${h.id}`;
    a.textContent = h.textContent?.trim() ?? '';
    wrapper.appendChild(a);
    li.appendChild(wrapper);
    tocList?.appendChild(li);
  });

  const links = [...(tocList?.querySelectorAll('.toc-widget__list-item-text') ?? [])];
  let prevActive = -1;

  function scrollTocToActive(index) {
    if (!tocBody || index < 0) return;
    const item = links[index]?.closest('li');
    if (!item) return;
    const itemTop    = (item as HTMLElement).offsetTop;
    const itemBottom = itemTop + (item as HTMLElement).offsetHeight;
    const scrollTop  = tocBody.scrollTop;
    const height     = tocBody.clientHeight;
    if (itemTop < scrollTop + 16)               tocBody.scrollTop = itemTop - 16;
    else if (itemBottom > scrollTop + height - 16) tocBody.scrollTop = itemBottom - height + 16;
  }

  function setActive() {
    let active = -1;
    headings.forEach((h, i) => {
      if (h.getBoundingClientRect().top <= window.innerHeight * 0.35) active = i;
    });
    links.forEach((l, i) => l.classList.toggle('is-active', i === active));
    if (active !== prevActive) { prevActive = active; scrollTocToActive(active); }
  }

  setActive();
  window.addEventListener('scroll', () => requestAnimationFrame(setActive), { passive: true });

  document.getElementById('toc-header')?.addEventListener('click', () => {
    sidebarToc?.classList.toggle('is-collapsed');
  });

  if (window.innerWidth <= 640) sidebarToc?.classList.add('is-collapsed');
})();
</script>
