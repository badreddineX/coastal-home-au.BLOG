---
import { getCollection } from 'astro:content';
import SEO     from '../components/SEO.astro';
import Header  from '../components/Header.astro';
import Footer  from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import '../styles/global.css';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime()
);
const featured = allPosts.slice(0, 3);
const latest   = allPosts.slice(0, 6);

const categories = [
  { label: 'Outdoor Entertaining', href: '/blog?cat=outdoor-entertaining' },
  { label: 'Coastal Decor',        href: '/blog?cat=coastal-decor'        },
  { label: 'Hamptons Style',       href: '/blog?cat=hamptons-style'       },
  { label: 'Backyard Ideas',       href: '/blog?cat=backyard-ideas'       },
];
---

<!doctype html>
<html lang="en-AU">
  <head>
    <SEO
      title="Outdoor & Coastal Home Decor — Australian Style"
      description="Coastal home decor and entertaining ideas for Australian homes. Hamptons style, alfresco dining, backyard inspiration — all for the Australian lifestyle."
      type="website"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <Header />
    <main id="main-content">

      <!-- ── Hero ── -->
      <section class="hero" aria-label="Hero">
        <img
          class="hero-bg"
          src="https://images.unsplash.com/photo-1600566753086-00f18fb6b3ea?auto=format&fit=crop&w=1600&q=80"
          alt="Bright Australian alfresco outdoor entertaining area"
          width="1600"
          height="900"
          loading="eager"
          fetchpriority="high"
        />
        <div class="hero-overlay"></div>
        <div class="container hero-content">
          <p class="hero-label">For Australian Homes</p>
          <h1 class="hero-headline">
            Outdoor &amp; Coastal Living,<br />
            <em>Done Beautifully</em>
          </h1>
          <p class="hero-sub">
            Coastal home decor and entertaining ideas for Australian homes —<br />
            written from the Southern Hemisphere.
          </p>
          <div class="hero-actions">
            <a href="/blog" class="btn hero-btn-primary">Browse Ideas</a>
            <a href="/about" class="btn hero-btn-ghost">Our Story</a>
          </div>
        </div>
      </section>

      <!-- ── //01 Featured Ideas ── -->
      <section class="section" aria-labelledby="featured-heading">
        <div class="container">
          <div class="featured-header">
            <h2 class="display featured-title" id="featured-heading">
              Ideas from the Coast
            </h2>
            <a href="/blog" class="btn btn-ghost">
              See all posts
              <svg viewBox="0 0 16 16" fill="none" width="13" height="13" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </a>
          </div>
          <div class="grid-3 featured-grid">
            {featured.map((post, i) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                slug={post.slug}
                image={post.data.image}
                category={post.data.category}
                readTime={post.data.readTime}
                datePublished={post.data.datePublished}
                index={i}
              />
            ))}
          </div>
        </div>
      </section>

      <!-- ── //02 Categories ── -->
      <section class="section section--warm" aria-labelledby="cat-heading">
        <div class="container">
          <h2 class="display cat-title" id="cat-heading">Discover Your Style</h2>
          <nav class="cat-list" aria-label="Browse by category">
            {categories.map((cat, i) => (
              <a href={cat.href} class="cat-item">
                <span class="cat-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="cat-name">{cat.label}</span>
                <svg class="cat-arrow" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </a>
            ))}
          </nav>
        </div>
      </section>

      <!-- ── Email Capture ── -->
      <section class="newsletter-section" aria-labelledby="newsletter-heading">
        <div class="container">
          <div class="newsletter-inner">
            <div class="newsletter-text">
              <p class="newsletter-label">Free, weekly</p>
              <h2 class="display newsletter-title" id="newsletter-heading">
                Get Coastal Ideas<br />Straight to Your Inbox
              </h2>
              <p class="newsletter-sub">No spam. Just fresh outdoor and coastal home ideas made for Australian homes, every week.</p>
            </div>
            <form class="newsletter-form" action="#" method="post" aria-label="Email newsletter signup">
              <div class="newsletter-field">
                <label for="email-input" class="sr-only">Your email address</label>
                <input
                  id="email-input"
                  type="email"
                  name="email"
                  placeholder="Your email address"
                  required
                  autocomplete="email"
                />
                <button type="submit">
                  Subscribe
                  <svg viewBox="0 0 16 16" fill="none" width="13" height="13" aria-hidden="true">
                    <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </button>
              </div>
              <p class="newsletter-privacy">By subscribing you agree to our <a href="/privacy-policy">privacy policy</a>. Unsubscribe anytime.</p>
            </form>
          </div>
        </div>
      </section>

      <!-- ── //03 Latest Posts ── -->
      <section class="section" aria-labelledby="latest-heading">
        <div class="container">
          <h2 class="display latest-title" id="latest-heading">Fresh from the Blog</h2>
          <div class="grid-2">
            {latest.map((post, i) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                slug={post.slug}
                image={post.data.image}
                category={post.data.category}
                readTime={post.data.readTime}
                datePublished={post.data.datePublished}
                index={i}
              />
            ))}
          </div>
          <div class="latest-cta">
            <a href="/blog" class="btn btn-primary">
              Browse the Blog
              <svg viewBox="0 0 16 16" fill="none" width="14" height="14" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </a>
          </div>
        </div>
      </section>

      <!-- ── //04 About ── -->
      <section class="section section--dark about-section" aria-labelledby="about-heading">
        <div class="container">
          <div class="about-split">
            <div class="about-img-col">
              <div class="about-logo-block">
                <span class="about-logo-monogram">O&amp;H</span>
                <span class="about-logo-wordmark">Outdoor &amp; Coastal-Home</span>
              </div>
            </div>
            <div class="about-text-col">
              <p class="about-label">G'day, I'm Sarah.</p>
              <h2 class="display about-headline" id="about-heading">
                Welcome To<br />Outdoor &amp; Coastal Home
              </h2>
              <p class="about-body">
                I started this blog because I was tired of beautiful home inspiration that was built for the Northern Hemisphere — with the wrong seasons, the wrong climate, and the wrong stores. Australians deserve content made for Australian homes.
              </p>
              <p class="about-body">
                Whether you have a backyard in Brisbane or a balcony in Sydney, I'm here with ideas that actually work in our climate, from retailers you can actually shop.
              </p>
              <a href="/about" class="btn about-btn">
                More About Me
                <svg viewBox="0 0 16 16" fill="none" width="13" height="13" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </section>

    </main>
    <Footer />
  </body>
</html>

<style>
/* ── Hero: full-width background image ── */
.hero {
  position: relative;
  width: 100%;
  min-height: 88vh;
  display: flex;
  align-items: center;
  overflow: hidden;
}
.hero-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}
.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to right, rgba(10,22,30,0.72) 0%, rgba(10,22,30,0.45) 60%, rgba(10,22,30,0.15) 100%);
}
.hero-content {
  position: relative;
  z-index: 1;
  padding-top: 80px;
  padding-bottom: 80px;
  max-width: 760px;
}
.hero-label {
  font-family: var(--font-heading);
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  color: rgba(255,255,255,0.65);
  margin: 0 0 20px 0;
}
.hero-headline {
  font-family: var(--font-heading);
  font-size: clamp(2.6rem, 6vw, 5rem);
  font-weight: 700;
  line-height: 1.05;
  color: #ffffff;
  margin: 0 0 24px 0;
}
.hero-headline em {
  font-family: var(--font-display);
  font-style: italic;
  font-weight: 400;
  color: var(--color-accent);
}
.hero-sub {
  font-size: clamp(0.95rem, 1.5vw, 1.05rem);
  color: rgba(255,255,255,0.75);
  line-height: 1.75;
  margin: 0 0 36px 0;
  max-width: 520px;
}
.hero-actions {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}
.hero-btn-primary {
  background: #ffffff;
  color: var(--color-heading);
  border: 2px solid #ffffff;
  font-family: var(--font-heading);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 14px 32px;
  text-decoration: none;
  transition: all 0.2s ease;
}
.hero-btn-primary:hover {
  background: transparent;
  color: #ffffff;
  text-decoration: none;
}
.hero-btn-ghost {
  background: rgba(255,255,255,0.12);
  color: #ffffff;
  border: 2px solid rgba(255,255,255,0.45);
  font-family: var(--font-heading);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 14px 32px;
  text-decoration: none;
  transition: all 0.2s ease;
}
.hero-btn-ghost:hover {
  background: rgba(255,255,255,0.22);
  color: #ffffff;
  text-decoration: none;
}

/* ── Newsletter / Email capture ── */
.newsletter-section {
  background: var(--color-dark);
  padding: 72px 0;
}
.newsletter-inner {
  display: grid;
  grid-template-columns: 1fr;
  gap: 40px;
  align-items: center;
}
@media (min-width: 900px) {
  .newsletter-inner { grid-template-columns: 1fr 1fr; gap: 64px; }
}
.newsletter-label {
  font-family: var(--font-heading);
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--color-accent-green);
  margin: 0 0 12px 0;
}
.newsletter-title {
  font-size: clamp(1.8rem, 4vw, 2.6rem);
  color: var(--color-white);
  margin: 0 0 16px 0;
  line-height: 1.15;
}
.newsletter-sub {
  font-size: 0.92rem;
  color: rgba(255,255,255,0.55);
  line-height: 1.7;
  margin: 0;
}
.newsletter-field {
  display: flex;
  gap: 0;
  margin-bottom: 12px;
}
.newsletter-field input {
  flex: 1;
  padding: 14px 18px;
  border: 1px solid rgba(255,255,255,0.2);
  background: rgba(255,255,255,0.07);
  color: var(--color-white);
  font-family: var(--font-body);
  font-size: 0.9rem;
  outline: none;
  transition: border-color 0.2s ease;
  min-width: 0;
}
.newsletter-field input::placeholder { color: rgba(255,255,255,0.35); }
.newsletter-field input:focus { border-color: rgba(255,255,255,0.5); }
.newsletter-field button {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 24px;
  background: var(--color-primary);
  color: var(--color-white);
  border: none;
  font-family: var(--font-heading);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  white-space: nowrap;
  transition: background 0.2s ease;
  flex-shrink: 0;
}
.newsletter-field button:hover { background: var(--color-primary-dark); }
.newsletter-privacy {
  font-size: 0.75rem;
  color: rgba(255,255,255,0.35);
  margin: 0;
  line-height: 1.5;
}
.newsletter-privacy a { color: rgba(255,255,255,0.5); text-decoration: underline; }
.newsletter-privacy a:hover { color: var(--color-white); }
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0,0,0,0);
  white-space: nowrap;
  border: 0;
}

/* ── Featured section ── */
.featured-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24px;
  margin-bottom: 40px;
}
.featured-title {
  font-size: clamp(2rem, 5vw, 3.2rem);
  margin: 0;
  line-height: 1.1;
}
.featured-grid { border: 1px solid var(--color-border); }
.featured-grid > :not(:last-child) { border-right: 1px solid var(--color-border); }

@media (min-width: 900px) {
  .featured-grid { border: 1px solid var(--color-border); }
  .featured-grid > :not(:last-child) { border-right: 1px solid var(--color-border); }
}
@media (max-width: 899px) {
  .featured-grid > * { border-bottom: 1px solid var(--color-border); }
  .featured-grid > :last-child { border-bottom: none; }
}

.featured-grid :global(.post-card) {
  padding: 20px;
  border: none;
}

/* Big format images on home page */
.featured-grid :global(.card-img) {
  aspect-ratio: 4 / 3;
}

/* ── Category section ── */
.cat-title {
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  margin-bottom: 40px;
  margin-top: 0;
}
.cat-list {
  display: flex;
  flex-direction: column;
  border-top: 1px solid var(--color-border);
}
.cat-item {
  display: flex;
  align-items: center;
  gap: 20px;
  padding: 22px 0;
  border-bottom: 1px solid var(--color-border);
  text-decoration: none;
  transition: all var(--transition);
}
.cat-item:hover { padding-left: 8px; text-decoration: none; }
.cat-num {
  font-family: var(--font-heading);
  font-size: 0.72rem;
  font-weight: 500;
  color: var(--color-text-muted);
  width: 28px;
  flex-shrink: 0;
}
.cat-name {
  font-family: var(--font-display);
  font-style: italic;
  font-size: clamp(1.2rem, 2.5vw, 1.7rem);
  color: var(--color-heading);
  flex: 1;
  transition: color var(--transition);
}
.cat-item:hover .cat-name { color: var(--color-primary); }
.cat-arrow {
  width: 20px;
  height: 20px;
  color: var(--color-text-muted);
  transition: transform var(--transition), color var(--transition);
}
.cat-item:hover .cat-arrow { transform: translateX(6px); color: var(--color-primary); }

/* ── Latest posts ── */
.latest-title {
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  margin-bottom: 40px;
  margin-top: 0;
}
.latest-cta {
  display: flex;
  justify-content: center;
  margin-top: 48px;
}

/* Big format images in latest grid */
.section .grid-2 :global(.card-img) {
  aspect-ratio: 4 / 3;
}

/* ── About section (dark) ── */
.about-section { color: rgba(255,255,255,0.8); }
.about-marker .marker-num,
.about-marker .marker-label { color: rgba(255,255,255,0.35); }
.about-marker { border-top-color: rgba(255,255,255,0.12); }

.about-split {
  display: grid;
  grid-template-columns: 1fr;
  gap: 48px;
  align-items: center;
}
.about-logo-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.12);
  aspect-ratio: 4 / 5;
  max-height: 480px;
  gap: 8px;
}
.about-logo-monogram {
  font-family: 'Pinyon Script', cursive;
  font-weight: 400;
  font-size: clamp(4rem, 10vw, 7rem);
  color: var(--color-white);
  line-height: 1;
  letter-spacing: 0.02em;
}
.about-logo-wordmark {
  font-family: var(--font-heading);
  font-size: clamp(0.4rem, 0.9vw, 0.58rem);
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.45);
  white-space: nowrap;
}
.about-label {
  font-family: var(--font-heading);
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--color-accent-green);
  margin-bottom: 12px;
}
.about-headline {
  font-size: clamp(2rem, 5vw, 3.2rem);
  color: var(--color-white);
  margin: 0 0 24px 0;
  line-height: 1.1;
}
.about-body {
  font-size: 0.95rem;
  color: rgba(255,255,255,0.65);
  line-height: 1.75;
}
.about-btn {
  background: transparent;
  color: var(--color-white);
  border-color: rgba(255,255,255,0.35);
  margin-top: 8px;
  display: inline-flex;
}
.about-btn:hover {
  background: var(--color-white);
  color: var(--color-heading);
  border-color: var(--color-white);
}

@media (min-width: 768px) {
  .about-split { grid-template-columns: 1fr 1fr; gap: 64px; }
}
</style>
