---
import { getCollection } from 'astro:content';
import SEO     from '../components/SEO.astro';
import Header  from '../components/Header.astro';
import Footer  from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import '../styles/global.css';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime()
);
const featured = allPosts.filter(p => p.data.featured === true).slice(0, 6);
const latest   = allPosts.filter(p => !p.data.featured).slice(0, 4);

function fmtDate(d: string) {
  return new Date(d).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' });
}

const categories = [
  { label: 'Outdoor Entertaining', href: '/blog?cat=outdoor-entertaining' },
  { label: 'Coastal Decor',        href: '/blog?cat=coastal-decor'        },
  { label: 'Hamptons Style',       href: '/blog?cat=hamptons-style'       },
  { label: 'Backyard Ideas',       href: '/blog?cat=backyard-ideas'       },
];
---

<!doctype html>
<html lang="en-AU">
  <head>
    <SEO
      title="Outdoor & Coastal Home Decor — Australian Style"
      description="Coastal home decor and entertaining ideas for Australian homes. Hamptons style, alfresco dining, backyard inspiration — all for the Australian lifestyle."
      type="website"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <Header />
    <main id="main-content">

      <!-- ── Hero ── -->
      <section class="hero" aria-label="Hero">
        <img
          class="hero-bg"
          src="https://images.unsplash.com/photo-1600566753086-00f18fb6b3ea?auto=format&fit=crop&w=1600&q=80"
          alt="Bright Australian alfresco outdoor entertaining area"
          width="1600"
          height="900"
          loading="eager"
          fetchpriority="high"
        />
        <div class="hero-overlay" aria-hidden="true"></div>
        <div class="container hero-content">
          <p class="hero-label">For Australian Homes</p>
          <h1 class="hero-headline">
            Outdoor &amp; Coastal Living,<br />
            <em>Done Beautifully</em>
          </h1>
          <p class="hero-sub">
            Coastal home decor and entertaining ideas for Australian homes —
            written from the Southern Hemisphere.
          </p>
          <div class="hero-actions">
            <a href="/blog" class="btn hero-btn-primary">Browse Ideas</a>
            <a href="/about" class="btn hero-btn-ghost">Our Story</a>
          </div>
        </div>
      </section>

      <!-- ── Editor's Picks ── -->
      <section class="editors-section" aria-labelledby="editors-heading">
        <div class="container">
          <div class="editors-header">
            <span class="editors-label" id="editors-heading">Editor's Picks</span>
            <a href="/blog" class="editors-view-all">All Posts →</a>
          </div>
          <div class="editors-grid">

            <!-- Large featured post -->
            <a href={`/blog/${featured[0].slug}`} class="editors-main" data-reveal>
              <div class="editors-main-img">
                <img
                  src={featured[0].data.image}
                  alt={featured[0].data.title}
                  width="900" height="675"
                  loading="eager"
                  fetchpriority="high"
                />
              </div>
              <span class="editors-cat">{featured[0].data.category}</span>
              <h2 class="editors-main-title">{featured[0].data.title}</h2>
              <span class="editors-meta">{fmtDate(featured[0].data.datePublished)} · {featured[0].data.readTime}</span>
            </a>

            <!-- Sidebar list -->
            <div class="editors-sidebar" data-reveal>
              {featured.slice(1).map(post => (
                <a href={`/blog/${post.slug}`} class="editors-item">
                  <img
                    class="editors-thumb"
                    src={post.data.image}
                    alt={post.data.title}
                    width="120" height="120"
                    loading="lazy"
                  />
                  <div class="editors-item-body">
                    <span class="editors-cat">{post.data.category}</span>
                    <h3 class="editors-item-title">{post.data.title}</h3>
                    <span class="editors-meta">{fmtDate(post.data.datePublished)} · {post.data.readTime}</span>
                  </div>
                </a>
              ))}
            </div>

          </div>
        </div>
      </section>

      <!-- ── //02 Categories ── -->
      <section class="section cat-section" aria-labelledby="cat-heading">
        <div class="container">
          <h2 class="display cat-title" id="cat-heading">Discover Your Style</h2>
          <nav class="cat-grid" aria-label="Browse by category">
            <a href={categories[0].href} class="cat-card cat-card--blue">
              <span class="cat-card-num">01</span>
              <span class="cat-card-name">{categories[0].label}</span>
              <svg class="cat-card-arrow" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </a>
            <a href={categories[1].href} class="cat-card cat-card--teal">
              <span class="cat-card-num">02</span>
              <span class="cat-card-name">{categories[1].label}</span>
              <svg class="cat-card-arrow" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </a>
            <a href={categories[2].href} class="cat-card cat-card--navy">
              <span class="cat-card-num">03</span>
              <span class="cat-card-name">{categories[2].label}</span>
              <svg class="cat-card-arrow" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </a>
            <a href={categories[3].href} class="cat-card cat-card--sand">
              <span class="cat-card-num">04</span>
              <span class="cat-card-name">{categories[3].label}</span>
              <svg class="cat-card-arrow" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </a>
          </nav>

          <!-- All Posts CTA -->
          <div class="cat-all-posts">
            <a href="/blog" class="cat-all-btn">
              View All Posts
              <svg viewBox="0 0 16 16" fill="none" width="16" height="16" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </a>
          </div>

        </div>
      </section>

      <!-- ── Email Capture ── -->
      <section class="newsletter-section" aria-labelledby="newsletter-heading">
        <div class="container">
          <div class="newsletter-inner">
            <div class="newsletter-text">
              <p class="newsletter-label">Free, weekly</p>
              <h2 class="display newsletter-title" id="newsletter-heading">
                Get Coastal Ideas<br />Straight to Your Inbox
              </h2>
              <p class="newsletter-sub">No spam. Just fresh outdoor and coastal home ideas made for Australian homes, every week.</p>
            </div>
            <form class="newsletter-form" action="#" method="post" aria-label="Email newsletter signup">
              <div class="newsletter-field">
                <label for="email-input" class="sr-only">Your email address</label>
                <input
                  id="email-input"
                  type="email"
                  name="email"
                  placeholder="Your email address"
                  required
                  autocomplete="email"
                />
                <button type="submit">
                  Subscribe
                  <svg viewBox="0 0 16 16" fill="none" width="13" height="13" aria-hidden="true">
                    <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </button>
              </div>
              <p class="newsletter-privacy">By subscribing you agree to our <a href="/privacy-policy">privacy policy</a>. Unsubscribe anytime.</p>
            </form>
          </div>
        </div>
      </section>

      <!-- ── //03 Latest Posts ── -->
      <section class="section" aria-labelledby="latest-heading">
        <div class="container">
          <h2 class="display latest-title" id="latest-heading">Fresh from the Blog</h2>
          <div class="grid-2">
            {latest.map((post, i) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                slug={post.slug}
                image={post.data.image}
                category={post.data.category}
                readTime={post.data.readTime}
                datePublished={post.data.datePublished}
                index={i}
              />
            ))}
          </div>
          <div class="latest-cta">
            <a href="/blog" class="btn btn-primary">
              Browse the Blog
              <svg viewBox="0 0 16 16" fill="none" width="14" height="14" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </a>
          </div>
        </div>
      </section>

      <!-- ── //04 About ── -->
      <section class="section section--dark about-section" aria-labelledby="about-heading">
        <div class="container">
          <div class="about-split">
            <div class="about-img-col">
              <div class="about-logo-block">
                <span class="about-logo-monogram">O &amp; H</span>
                <span class="about-logo-wordmark">Outdoor &amp; Coastal-Home</span>
              </div>
            </div>
            <div class="about-text-col">
              <p class="about-label">G'day, I'm Badreddine.</p>
              <h2 class="display about-headline" id="about-heading">
                Welcome To<br />Outdoor &amp; Coastal-Home
              </h2>
              <p class="about-body">
                I started this blog because I was tired of beautiful home inspiration that was built for the Northern Hemisphere — with the wrong seasons, the wrong climate, and the wrong stores. Australians deserve content made for Australian homes.
              </p>
              <p class="about-body">
                Whether you have a backyard in Brisbane or a balcony in Sydney, I'm here with ideas that actually work in our climate, from retailers you can actually shop.
              </p>
              <a href="/about" class="btn about-btn">
                More About Me
                <svg viewBox="0 0 16 16" fill="none" width="13" height="13" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </section>

    </main>
    <Footer />
  </body>
</html>

<style>
/* ── Hero ── */
.hero {
  position: relative;
  width: 100%;
  min-height: 80vh;
  display: flex;
  align-items: center;
  overflow: hidden;
}
.hero-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}
.hero-overlay {
  position: absolute;
  inset: 0;
  background: rgba(20, 30, 40, 0.52);
}
.hero-content {
  position: relative;
  z-index: 2;
  padding-top: 80px;
  padding-bottom: 80px;
  max-width: 780px;
}
.hero-label {
  font-family: var(--font-heading);
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  color: rgba(255,255,255,0.65);
  margin: 0 0 20px 0;
}
.hero-headline {
  font-family: var(--font-heading);
  font-size: clamp(2.6rem, 6vw, 5rem);
  font-weight: 700;
  line-height: 1.05;
  color: #ffffff;
  margin: 0 0 24px 0;
}
.hero-headline em {
  font-family: var(--font-display);
  font-style: italic;
  font-weight: 400;
  color: var(--color-accent);
  display: block;
}
.hero-sub {
  font-size: clamp(0.95rem, 1.5vw, 1.05rem);
  color: rgba(255,255,255,0.75);
  line-height: 1.75;
  margin: 0 0 36px 0;
  max-width: 540px;
}
.hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }
.hero-btn-primary {
  background: #ffffff;
  color: var(--color-heading);
  border: 2px solid #ffffff;
  font-family: var(--font-heading);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 14px 32px;
  text-decoration: none;
  transition: all 0.2s ease;
}
.hero-btn-primary:hover { background: transparent; color: #ffffff; text-decoration: none; }
.hero-btn-ghost {
  background: rgba(255,255,255,0.10);
  color: #ffffff;
  border: 2px solid rgba(255,255,255,0.40);
  font-family: var(--font-heading);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 14px 32px;
  text-decoration: none;
  transition: all 0.2s ease;
}
.hero-btn-ghost:hover { background: rgba(255,255,255,0.20); color: #ffffff; text-decoration: none; }


/* ── Editor's Picks ── */
.editors-section {
  padding: 48px 0 64px;
  background: var(--color-bg);
}
.editors-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
  padding: 12px 0;
  margin-bottom: 36px;
}
.editors-label {
  font-family: var(--font-heading);
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  color: var(--color-heading);
}
.editors-view-all {
  font-family: var(--font-heading);
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  color: var(--color-heading);
  text-decoration: none;
  transition: color var(--transition);
}
.editors-view-all:hover { color: var(--color-primary); text-decoration: none; }

.editors-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 40px;
}
@media (min-width: 900px) {
  .editors-grid { grid-template-columns: 3fr 2fr; gap: 56px; }
}

/* Large main post */
.editors-main {
  display: block;
  text-decoration: none;
}
.editors-main:hover { text-decoration: none; }
.editors-main-img {
  aspect-ratio: 4 / 3;
  overflow: hidden;
  margin-bottom: 18px;
}
.editors-main-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}
.editors-main:hover .editors-main-img img { transform: scale(1.03); }
.editors-main-title {
  font-family: var(--font-display);
  font-style: italic;
  font-size: clamp(1.5rem, 2.5vw, 2rem);
  font-weight: 400;
  color: var(--color-heading);
  line-height: 1.25;
  margin: 8px 0 10px;
}
.editors-main:hover .editors-main-title { color: var(--color-primary); }

/* Sidebar items */
.editors-sidebar {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.editors-item {
  display: flex;
  gap: 18px;
  align-items: flex-start;
  text-decoration: none;
  padding: 22px 0;
  border-bottom: 1px solid var(--color-border);
}
.editors-item:first-child { padding-top: 0; }
.editors-item:last-child { border-bottom: none; }
.editors-item:hover { text-decoration: none; }
.editors-thumb {
  width: 96px;
  height: 96px;
  object-fit: cover;
  flex-shrink: 0;
}
.editors-item-body { flex: 1; min-width: 0; }
.editors-item-title {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1.05rem;
  font-weight: 400;
  color: var(--color-heading);
  line-height: 1.35;
  margin: 6px 0 8px;
}
.editors-item:hover .editors-item-title { color: var(--color-primary); }

/* Shared meta */
.editors-cat {
  font-family: var(--font-heading);
  font-size: 0.63rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--color-primary);
  display: block;
}
.editors-meta {
  font-family: var(--font-heading);
  font-size: 0.75rem;
  color: var(--color-text-muted);
  display: block;
}

/* ── Newsletter / Email capture ── */
.newsletter-section {
  background: var(--color-dark);
  padding: 72px 0;
}
.newsletter-inner {
  display: grid;
  grid-template-columns: 1fr;
  gap: 40px;
  align-items: center;
}
@media (min-width: 900px) {
  .newsletter-inner { grid-template-columns: 1fr 1fr; gap: 64px; }
}
.newsletter-label {
  font-family: var(--font-heading);
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--color-accent-green);
  margin: 0 0 12px 0;
}
.newsletter-title {
  font-size: clamp(1.8rem, 4vw, 2.6rem);
  color: var(--color-white);
  margin: 0 0 16px 0;
  line-height: 1.15;
}
.newsletter-sub {
  font-size: 0.92rem;
  color: rgba(255,255,255,0.55);
  line-height: 1.7;
  margin: 0;
}
.newsletter-field {
  display: flex;
  gap: 0;
  margin-bottom: 12px;
}
.newsletter-field input {
  flex: 1;
  padding: 14px 18px;
  border: 1px solid rgba(255,255,255,0.2);
  background: rgba(255,255,255,0.07);
  color: var(--color-white);
  font-family: var(--font-body);
  font-size: 0.9rem;
  outline: none;
  transition: border-color 0.2s ease;
  min-width: 0;
}
.newsletter-field input::placeholder { color: rgba(255,255,255,0.35); }
.newsletter-field input:focus { border-color: rgba(255,255,255,0.5); }
.newsletter-field button {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 24px;
  background: var(--color-primary);
  color: var(--color-white);
  border: none;
  font-family: var(--font-heading);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  white-space: nowrap;
  transition: background 0.2s ease;
  flex-shrink: 0;
}
.newsletter-field button:hover { background: var(--color-primary-dark); }
.newsletter-privacy {
  font-size: 0.75rem;
  color: rgba(255,255,255,0.35);
  margin: 0;
  line-height: 1.5;
}
.newsletter-privacy a { color: rgba(255,255,255,0.5); text-decoration: underline; }
.newsletter-privacy a:hover { color: var(--color-white); }
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0,0,0,0);
  white-space: nowrap;
  border: 0;
}


/* ── Category squares ── */
.cat-section { background: var(--color-bg); }
.cat-title {
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  margin-bottom: 40px;
  margin-top: 0;
}
.cat-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
}
@media (min-width: 768px) {
  .cat-grid { grid-template-columns: repeat(4, 1fr); gap: 20px; }
}
.cat-card {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 28px 24px 24px;
  aspect-ratio: 1 / 1;
  text-decoration: none;
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}
.cat-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,0.15); text-decoration: none; }
.cat-card--blue  { background: #4A90B8; }
.cat-card--teal  { background: #7BBFB5; }
.cat-card--navy  { background: #1B3A4B; }
.cat-card--sand  { background: #C8A882; }
.cat-card-num {
  font-family: var(--font-heading);
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: rgba(255,255,255,0.55);
}
.cat-card-name {
  font-family: var(--font-display);
  font-style: italic;
  font-size: clamp(1.1rem, 2vw, 1.45rem);
  font-weight: 400;
  color: #ffffff;
  line-height: 1.25;
  flex: 1;
  display: flex;
  align-items: center;
  padding: 12px 0;
}
.cat-card-arrow {
  width: 20px;
  height: 20px;
  color: rgba(255,255,255,0.65);
  transition: transform var(--transition);
  align-self: flex-end;
}
.cat-card:hover .cat-card-arrow { transform: translateX(5px); color: #ffffff; }

.cat-all-posts { margin-top: 20px; }
.cat-all-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  width: 100%;
  padding: 22px;
  background: var(--color-heading);
  font-family: var(--font-display);
  font-style: italic;
  font-size: clamp(1.1rem, 2vw, 1.4rem);
  font-weight: 400;
  color: #ffffff;
  text-decoration: none;
  transition: opacity 0.2s ease;
}
.cat-all-btn:hover { opacity: 0.88; text-decoration: none; }
.cat-all-btn svg { transition: transform var(--transition); }
.cat-all-btn:hover svg { transform: translateX(5px); }

/* ── Latest posts ── */
.latest-title {
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  margin-bottom: 40px;
  margin-top: 0;
}
.latest-cta {
  display: flex;
  justify-content: center;
  margin-top: 48px;
}

/* Big format images in latest grid */
.section .grid-2 :global(.card-img) {
  aspect-ratio: 4 / 3;
}

/* ── About section (dark) ── */
.about-section { color: rgba(255,255,255,0.8); }
.about-marker .marker-num,
.about-marker .marker-label { color: rgba(255,255,255,0.35); }
.about-marker { border-top-color: rgba(255,255,255,0.12); }

.about-split {
  display: grid;
  grid-template-columns: 1fr;
  gap: 48px;
  align-items: center;
}
.about-logo-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  aspect-ratio: 4 / 5;
  max-height: 480px;
  gap: 8px;
}
.about-logo-monogram {
  font-family: 'Pinyon Script', cursive;
  font-weight: 400;
  font-size: clamp(4rem, 10vw, 7rem);
  color: var(--color-white);
  line-height: 1;
  letter-spacing: 0.02em;
}
.about-logo-wordmark {
  font-family: var(--font-heading);
